# ================================================
# FORGE - Environment Variables
# ================================================
# Copy this file to .env.local for local dev
# Add these as Environment Variables in Vercel dashboard
# ================================================

# Supabase project credentials (get from: supabase.com → Project → Settings → API)
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Sentry error monitoring (get from: sentry.io → Project → Settings → Client Keys)
# Leave blank to disable Sentry (errors won't be reported in dev by default anyway)
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Sentry release tracking — required for source map uploads and GitHub release integration.
# Get auth token from: sentry.io → Settings → Auth Tokens → Create New Token (scope: project:releases)
# Get org/project slugs from the URL: sentry.io/organizations/<ORG>/projects/<PROJECT>/
# Add all three as GitHub Actions secrets AND Vercel environment variables.
SENTRY_AUTH_TOKEN=sntrys_your_auth_token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Google Analytics 4 (get from: analytics.google.com → Admin → Data Streams → Measurement ID)
# Format: G-XXXXXXXXXX — leave blank to disable analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Twitch stream archiving (get from: dev.twitch.tv → Your Console → Applications → Register Your Application)
# Redirect URI to add in Twitch console: https://forge-social.app/settings/twitch-archive
VITE_TWITCH_CLIENT_ID=your_twitch_client_id
# Server-side only — add to Supabase edge function secrets
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# hCaptcha (get from: dashboard.hcaptcha.com → Sites → Add New Site)
# Leave blank to disable CAPTCHA on the signup form
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
# hCaptcha secret key — server-side only, never prefix with VITE_
# Also paste this into: Supabase → Auth → Bot and Abuse Protection → hCaptcha secret
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# Stripe payments (get from: dashboard.stripe.com → Developers → API Keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
# Webhook secret — get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Supabase service role key (server-side only) — for webhook to update profiles
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ================================================
# SETUP CHECKLIST
# ================================================
# 1. Create a Supabase project at https://supabase.com
# 2. Enable Google OAuth: Supabase Dashboard → Auth → Providers → Google
#    - Create Google OAuth credentials at: https://console.cloud.google.com
#    - Set Authorized redirect URI to: https://<your-project>.supabase.co/auth/v1/callback
# 3. Set your site URL in Supabase: Auth → URL Configuration → Site URL
# 4. Add your deployed Vercel URL to: Auth → URL Configuration → Redirect URLs
# 5. Create a Sentry project at sentry.io → get DSN from Settings → Client Keys
#    For GitHub release tracking:
#    a. Create a Sentry auth token (Settings → Auth Tokens, scope: project:releases)
#    b. Add SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT to:
#       - GitHub repo → Settings → Secrets and variables → Actions
#       - Vercel → Project Settings → Environment Variables
#    c. Install the Sentry GitHub app: sentry.io → Settings → Integrations → GitHub
#    d. To cut a named release: GitHub → Releases → Draft a new release → Publish
# 6. Create a GA4 property at analytics.google.com → get Measurement ID from Data Streams
# 7. Stripe: Get keys from dashboard.stripe.com → Developers → API Keys
#    - Create a webhook at Stripe Dashboard → Webhooks → Add endpoint
#    - Endpoint URL: https://forge-social.app/api/stripe/webhook
#    - Event to listen for: payment_intent.succeeded
#    - Copy signing secret → STRIPE_WEBHOOK_SECRET
# 8. CAPTCHA: Create a site at dashboard.hcaptcha.com
#    - Add domains: forge-social.app and localhost
#    - Copy Site Key → VITE_HCAPTCHA_SITE_KEY (public)
#    - Copy Secret Key → HCAPTCHA_SECRET_KEY (server-side) + Supabase → Auth → Bot and Abuse Protection → hCaptcha secret
# ================================================
